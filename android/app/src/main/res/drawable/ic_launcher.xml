<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">
    <!-- Dark deep cyber background -->
    <path
        android:fillColor="#070A12"
        android:pathData="M 0,0 L 100,0 L 100,100 L 0,100 Z"/>
    <!-- Futuristic shield grid -->
    <path
        android:strokeColor="#1E293B"
        android:strokeWidth="1.5"
        android:pathData="M 20,10 L 80,10 L 90,40 L 50,90 L 10,40 Z"/>
    <!-- Outer neon radar ring -->
    <path
        android:strokeColor="#00F2FE"
        android:strokeWidth="3.5"
        android:pathData="M 50,15 A 35,35 0 1, 1 49.99,15 Z"/>
    <!-- Scanner core crosshairs -->
    <path
        android:strokeColor="#00EBD8"
        android:strokeWidth="2"
        android:pathData="M 50,5 L 50,95 M 5,50 L 95,50"/>
    <!-- High-tech core circle -->
    <path
        android:fillColor="#00F2FE"
        android:pathData="M 50,42 A 8,8 0 1, 1 49.99,42 Z"/>
</vector>
