<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Header Banner -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANSH9BOSS"
        android:textColor="#00F2FE"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minecraft Mod Analyzer & Anti-Cheat Scan"
        android:textColor="#8A9FC2"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Action Buttons -->
    <Button
        android:id="@+id/btnSelectFolder"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Select PojavLauncher Folder"
        android:backgroundTint="#0C111E"
        android:textColor="#00F2FE"
        app:strokeColor="#00F2FE"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnStartScan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Start Scan"
        android:backgroundTint="#00F2FE"
        android:textColor="#070A12"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/btnSelectFolder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Progress Indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:indeterminate="false"
        android:visibility="gone"
        android:progressTint="#00EBD8"
        app:layout_constraintTop_toBottomOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Console Logging Screen -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#04060B"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="Console ready. Click 'Select PojavLauncher Folder' to link .minecraft mods directory...\n"
            android:textColor="#8A9FC2"
            android:textSize="11sp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
