<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Glowing Cyber Header -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ANSH9BOSS"
        android:textColor="#00F2FE"
        android:textSize="32sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minecraft Mod Analyzer &amp; Anti-Cheat Scan"
        android:textColor="#8A9FC2"
        android:textSize="12sp"
        android:letterSpacing="0.05"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Centered Scanning Radar SVG (Vector) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutRadar"
        android:layout_width="180dp"
        android:layout_height="180dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <!-- Outer Ring Glow -->
        <View
            android:id="@+id/viewGlowRing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/ic_launcher"
            android:alpha="0.2" />

        <!-- Rotating Radar Vector -->
        <ImageView
            android:id="@+id/ivScannerLogo"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/ic_launcher"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Progress Indicator with percentage / metrics -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:indeterminate="false"
        android:visibility="invisible"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:progressTint="#00EBD8"
        android:progressBackgroundTint="#1E293B"
        app:layout_constraintBottom_toTopOf="@id/btnSelectFolder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons with cyber borders -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSelectFolder"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Select PojavLauncher Folder"
        android:textColor="#00F2FE"
        android:textSize="13sp"
        android:letterSpacing="0.05"
        app:backgroundTint="#0C111E"
        app:strokeColor="#00F2FE"
        app:strokeWidth="1.5dp"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toTopOf="@id/btnStartScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScan"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="Start Scan"
        android:textColor="#070A12"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:enabled="false"
        app:backgroundTint="#00F2FE"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toTopOf="@id/scrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- Terminal Console Console Display -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:background="#04060B"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="Console ready. Click 'Select PojavLauncher Folder' to link .minecraft mods directory...\n"
            android:textColor="#8A9FC2"
            android:textSize="11sp"
            android:lineSpacingExtra="2dp"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
